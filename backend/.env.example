DATABASE_TYPE=sqlite
SQLITE_URL=sqlite:///./app.db
MONGO_URL=mongodb://localhost:27017
MONGO_DB_NAME=webdev-ai

JWT_SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30

ENCRYPTION_KEY=

# Fernet master key for secrets vault (SSH keys, API keys, PATs).
# Generate with: python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_MASTER_KEY=

RATE_LIMIT_USER=60
RATE_LIMIT_API_CLIENT=100

CORS_ORIGINS=["http://localhost:3100"]

PROJECTS_DATA_DIR=./data/projects

DOCKER_SOCKET=
CONTAINER_IDLE_TIMEOUT_MINUTES=30
CONTAINER_HARD_REMOVE_HOURS=48

QDRANT_URL=http://localhost:6333

ANTHROPIC_API_KEY=
OPENAI_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434
LMSTUDIO_BASE_URL=http://localhost:1234/v1

TAVILY_API_KEY=

# ── Git Integration ──────────────────────────────────────────────────
# No additional env vars required for git SSH integration.
# SSH keypairs are generated per-project and stored encrypted in the vault.
# Users generate a key via POST /vault/ssh/generate, then add the returned
# public key to their GitHub/GitLab account under Settings → SSH Keys.
#
# Optional: pre-configure a global git identity for commits made inside containers.
GIT_AUTHOR_NAME=
GIT_AUTHOR_EMAIL=
